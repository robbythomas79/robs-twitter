# ── Twitter API credentials (required) ───────────────────────────────────────
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN_KEY=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# ── What to stream (set at least one) ────────────────────────────────────────
# Comma-separated Twitter screen names to follow (live tweets from these accounts)
TWITTER_FOLLOW_ACCOUNTS=NASA,BBCNews,Reuters

# Comma-separated keywords to track (optional, combine with FOLLOW_ACCOUNTS)
TWITTER_TRACK_KEYWORDS=

# Language filter — BCP-47 codes, comma-separated (leave empty for all languages)
TWITTER_LANGUAGES=en

# ── Kafka settings (defaults match docker-compose) ────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=twitterTopic
KAFKA_GROUP_ID=robs-twitter-frontend

# ── Frontend server ───────────────────────────────────────────────────────────
PORT=3000
